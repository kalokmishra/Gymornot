# NextAuth Configurations
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=developmentsupersecretkeychangeinproduction

# Google OAuth Credentials
# Retrieve these from Google Cloud Console (APIs & Services > Credentials)
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Admin Access Configuration (comma-separated emails allowed to access admin routes)
ADMIN_USERS=admin@gymornot.com,you@gmail.com
